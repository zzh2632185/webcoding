# Web 登录密码（可选，不设则首次启动自动生成随机密码）
# CC_WEB_PASSWORD=your-password-here

# 服务监听端口（默认 8001）
PORT=8001

# 监听地址（默认 0.0.0.0）
# 仅本机使用时建议改为 127.0.0.1
HOST=0.0.0.0

# 单条 WebSocket 消息上限，单位字节（默认 4 MB）
CC_WEB_WS_MAX_PAYLOAD=4194304

# Claude CLI 路径（默认在 PATH 中查找 claude）
CLAUDE_PATH=claude

# Codex CLI 路径（默认在 PATH 中查找 codex）
CODEX_PATH=codex

# Pi CLI 路径（默认在 PATH 中查找 pi，包名 @earendil-works/pi-coding-agent）
PI_PATH=pi

# CLI 自定义配置目录（可选，默认分别为 ~/.claude 与 ~/.codex）
# CLAUDE_CONFIG_DIR=/absolute/path/to/claude-config
# CODEX_HOME=/absolute/path/to/codex-home

# 额外传给 Agent 子进程的变量名（可选，逗号分隔；不要填写变量值）
# CC_WEB_CLI_ENV_PASSTHROUGH=GH_TOKEN,MY_PROVIDER_KEY

# PushPlus Token（可选，首次启动会自动迁移到 config/notify.json）
PUSHPLUS_TOKEN=
